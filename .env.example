# Copy to `.env` and adjust. Compose reads this file for containers (create it before `docker compose up`).
#
# When you run **`docker compose up`**, the **`web`** service sets DATABASE_URL to Postgres service **`db`**
# inside the network—you normally keep DATABASE_URL below for **local** Python (host port 15433).
#
# Values in this repo's `.env` override existing Windows/user environment variables for the same keys
# (so a wrong machine-level DATABASE_URL cannot silently break local Docker).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:15433/aml_web

# Display name for the current user when there is no auth middleware (notes author, status actor,
# and auto-assigned senior when moving New / Pending evidence → an initial outcome).
APP_TITLE=Hosted Checkout Monitoring system
APP_ACTOR_NAME=Demo user

# Secret for signed browser sessions (change in production).
SESSION_SECRET=change-me-to-a-long-random-string

# First admin account (after migrations), from the repository root (no angle brackets — use real values; quote if spaces/special chars):
#   python -m app.scripts.create_admin myuser "myP@ssw0rd" "Display name"

# Maximum Excel upload size in bytes (default 26214400 ≈ 25 MiB if unset).
# MAX_UPLOAD_BYTES=26214400

# --- MariaDB / MySQL (minitrans) enrichment and risk lookup ---
# Used when you run scenarios from the web UI or desktop tool:
# - wallet profile enrichment (actors_clean1_clone)
# - high-risk debit lookup (minitrans_clone)
# If unset or connection fails, scenarios still run; enrichment/risk lookup fields are left low/empty
# and warnings are written to app logs.
# Requires: pip install pymysql (included in requirements.txt).
#
# MINITRANS_HOST=127.0.0.1
# MINITRANS_PORT=3306
# MINITRANS_USER=minitrans_user
# MINITRANS_PASSWORD=minitrans_password
# MINITRANS_DATABASE=your_database

# Optional: Excel path for city code → display name (GOV_MAPPING_PATH). Empty = use raw city codes only.
# GOV_MAPPING_PATH=mapping/cities.xlsx
