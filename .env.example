DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:15433/aml_web

# Docker Compose `db` uses this for the container password (default: postgres if unset).
# If you set POSTGRES_PASSWORD, use the same password in DATABASE_URL above for a host-run app.
# POSTGRES_PASSWORD=

# --- Google Cloud SQL (PostgreSQL) ---
# GCP does not give "always-free" Cloud SQL; use trial credits or the smallest SKU.
# 1. Create Cloud SQL Postgres instance + database (e.g. aml_web) + user/password in GCP Console.
# 2a. Public IP path: add your IP under "Authorized networks", then require TLS in the URL:
#     DATABASE_URL=postgresql://CLOUD_SQL_USER:CLOUD_SQL_PASS@PUBLIC_IP/dbname?sslmode=require
#     If the password has @ # % etc., URL-encode it (use an online encoder or set a password without specials).
# 2b. Safer dev path: Cloud SQL Auth Proxy listens on localhost; disable SSL between app and proxy:
#     DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/dbname
# Run migrations from this repo root: python -m alembic upgrade head

# UI title (header + browser tab)
APP_TITLE=Hosted Checkout Monitoring system
# First admin account (after migrations), from aml_web directory:
#   python -m app.scripts.create_admin myuser "myP@ssw0rd" "Display name"

# Maximum Excel upload size in bytes (default 26214400 ≈ 25 MiB if unset).
# MAX_UPLOAD_BYTES=26214400

# --- Optional: MariaDB/MySQL (minitrans) — actors_clean1_clone + minitrans_clone ---
# Used when you run scenarios from the web UI or desktop tool: MSISDN → full name + city
# are merged into detection metrics (WalletHolderName, WalletCityName, or *Pipe variants).
# If unset or connection fails, scenarios still run; names/cities are left empty (see app logs).
# Requires: pip install pymysql (included in aml_web/requirements.txt).
MINITRANS_USER=
MINITRANS_PASSWORD=
MINITRANS_HOST=
MINITRANS_PORT=
MINITRANS_DATABASE=
GOV_MAPPING_PATH=./Gov_mapping.xlsx