# Example Nginx reverse proxy for AML web on RHEL 9.
# Install: sudo dnf install -y nginx
# Copy to /etc/nginx/conf.d/aml-web.conf (adjust server_name and TLS paths).
#
# In .env (web container), set for HTTPS:
#   ENV=production
#   SECURE_COOKIES=true
#   SESSION_SAME_SITE=strict
#   FORWARDED_ALLOW_IPS=127.0.0.1

upstream aml_web {
    server 127.0.0.1:8000;
    keepalive 8;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name aml.example.com;

    ssl_certificate     /etc/pki/tls/certs/aml-web.crt;
    ssl_certificate_key /etc/pki/tls/private/aml-web.key;

    client_max_body_size 26m;

    location / {
        proxy_pass http://aml_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name aml.example.com;
    return 301 https://$host$request_uri;
}
